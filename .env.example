# Copy to .env.local and fill values. Never commit .env.local.

# --- AI (server-side only; never NEXT_PUBLIC_*) ---
# OpenAI-compatible base URL (9router local default)
AI_ENDPOINT=http://127.0.0.1:20128/v1
# Required unless user sets BYOK in Settings page
AI_API_KEY=
AI_MODEL=XM/mimo-v2.5-pro

# --- Supabase (optional; app currently uses static data, not required for demo) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# --- OmahBan POS live stock (server-only; never NEXT_PUBLIC_*) ---
# snapshot (default) = src/data/shop-stock.json
# live = GET {OMAHBAN_API_URL}/api/products with Sanctum Bearer token
STOCK_SOURCE=snapshot
# OMAHBAN_API_URL=http://127.0.0.1:8000
# OMAHBAN_API_TOKEN=

